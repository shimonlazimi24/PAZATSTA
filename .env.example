# Database (required).
# DATABASE_URL = pooler for runtime (Supabase: Transaction mode port 6543 recommended for serverless).
# DIRECT_URL = for migrations. Vercel can't reach direct (db.xxx) - use Session mode pooler instead:
#   Supabase Dashboard → Connect → "Session mode" (not Direct). Format:
#   postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://user:password@host:5432/postgres"
DIRECT_URL="postgresql://postgres.PROJECT_REF:password@aws-0-REGION.pooler.supabase.com:5432/postgres"
RESEND_API_KEY="re_xxxx"
# Optional. Omit RESEND_FROM to use onboarding@resend.dev (only delivers to your Resend account email).
# To send to any address: verify domain in Resend → Domains, then set e.g. RESEND_FROM="info@pazatsta.co.il"
# RESEND_FROM="info@pazatsta.co.il"
APP_URL="http://localhost:3000"
COOKIE_SECRET="min-32-chars-random-string-for-signing"
# If using www + non-www: set COOKIE_DOMAIN=.yourdomain.com so cookie works on both
# COOKIE_DOMAIN=".pazatsta-schedule.com"

# Admin: receives approval notifications when a student books a lesson.
# Default: shachar.cygler@gmail.com. Override with ADMIN_NOTIFICATION_EMAILS to add more.
# ADMIN_NOTIFICATION_EMAILS="your-admin@example.com"

# Contact (shown in footer). Optional: NEXT_PUBLIC_CONTACT_EMAIL, NEXT_PUBLIC_CONTACT_PHONE
NEXT_PUBLIC_CONTACT_EMAIL="info@pazatsta.co.il"
NEXT_PUBLIC_CONTACT_PHONE="050-2632320"

# PDF storage (default: ./storage/pdfs). For Vercel use Vercel Blob or similar.
STORAGE_PATH="./storage/pdfs"

# Cron: set a secret; call endpoints with Authorization: Bearer <CRON_SECRET>
# - GET /api/cron/follow-up (daily: teacher reminder on student screening date)
# - GET /api/cron/weekly-hours (weekly: hours summary to admin for payment)
# See docs/CRON.md for how to schedule (Vercel Cron or cron-job.org etc.).
CRON_SECRET=""
